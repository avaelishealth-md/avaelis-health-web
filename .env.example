# AvaElis site environment. Copy to .env.local (gitignored) for local dev;
# set the same values in Vercel -> Project Settings -> Environment Variables for deploy.

# Supabase — Danny's avaelis-prod project (Supabase dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET   # server-only; never exposed to the browser

# Admin allow-list — comma-separated emails permitted to log into /admin
ADMIN_ALLOWLIST=jason@avaelishealth.com,drdannycai@avaelishealth.com.au

# Mailchimp (already set in Vercel)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# Resend — transactional email (add when ready)
RESEND_API_KEY=
RESEND_FROM=AvaElis Health <hello@avaelishealth.com.au>
