# AvaElis site environment. Copy to .env.local (gitignored) for local dev;
# set the same values in Vercel -> Project Settings -> Environment Variables for deploy.

# Supabase — Danny's avaelis-prod project (Supabase dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET   # server-only; never exposed to the browser

# Admin allow-list — comma-separated emails permitted to log into /admin
ADMIN_ALLOWLIST=jason@avaelishealth.com,drdannycai@avaelishealth.com.au,nikki@avaelishealth.com.au

# Mailchimp — ALL site forms (enquiry, newsletter, /talk-summary) read these two.
# The server prefix (usXX) is derived from the key automatically; no separate DC var.
# To REPOINT the site to the NEW (info@) account: set these to the NEW account's
# values in Vercel (Production + Preview), then redeploy. No code change required.
MAILCHIMP_API_KEY=        # NEW account API key (ends in -usXX)
MAILCHIMP_LIST_ID=        # NEW account Audience ID

# One-time audience migration only (scripts/migrate-mailchimp.mjs).
# Put REAL values in .env.local (gitignored), NEVER here. See the script header.
OLD_MC_API_KEY=
OLD_MC_AUDIENCE_ID=
NEW_MC_API_KEY=
NEW_MC_AUDIENCE_ID=

# Resend — transactional email (add when ready)
RESEND_API_KEY=
RESEND_FROM=AvaElis Health <hello@avaelishealth.com.au>

# Content-engine -> blog ingest. Shared secret; must equal the engine's AVAELIS_INGEST_SECRET.
INGEST_SECRET=
NEXT_PUBLIC_SITE_URL=https://avaelishealth.com.au
